rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write, delete: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /announcements/{announcementId} {
      allow read, write, delete: if true;
    }
  }
}

